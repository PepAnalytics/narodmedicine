DEBUG=False
SERVICE_NAME=folk-medicine-backend
APP_VERSION=1.0.0
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-at-least-50-characters

ALLOWED_HOSTS=api.example.com
CSRF_TRUSTED_ORIGINS=https://api.example.com

POSTGRES_DB=folk_medicine
POSTGRES_USER=folk_user
POSTGRES_PASSWORD=strong-production-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgres://folk_user:strong-production-password@db:5432/folk_medicine
DATABASE_CONN_MAX_AGE=120
DATABASE_CONN_HEALTH_CHECKS=True

REDIS_URL=redis://redis:6379/1

# HTTPS and proxy
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
USE_X_FORWARDED_HOST=True
ENABLE_PROXY_SSL_HEADER=True
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
X_FRAME_OPTIONS=DENY

# CORS
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGIN_REGEXES=
CORS_ALLOW_CREDENTIALS=False
CORS_ALLOW_METHODS=DELETE,GET,OPTIONS,PATCH,POST,PUT
CORS_ALLOW_HEADERS=Accept,Accept-Language,Authorization,Content-Language,Content-Type,Origin,User-Agent,X-Requested-With,X-User-Id
CORS_EXPOSE_HEADERS=Content-Type,X-User-Id

# Firebase
FCM_CREDENTIALS_PATH=/run/secrets/firebase-service-account.json
FCM_PROJECT_ID=

# Cache
CATALOG_CACHE_TTL=3600
LEGAL_CACHE_TTL=3600
POPULAR_DISEASES_LIMIT=10

# Logging
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO
LOG_FILE=

# Gunicorn
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
GUNICORN_LOG_LEVEL=info
